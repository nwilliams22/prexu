{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Prexu",
  "version": "0.6.3",
  "identifier": "com.prexu.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Prexu",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http: ws: wss:; img-src 'self' https: http: data:; media-src 'self' https: http: blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks/hooks.nsh"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBRjMyMzg0MjJBMjk2QjEKUldTeGxxSWloQ1B6S2x6bDNYR3RXTFZNT2lMa1NxdzR3SU9FWURSbWkxZjVTeXMxR2ZYRTZQYncK",
      "endpoints": [
        "https://github.com/nwilliams22/prexu/releases/latest/download/latest.json"
      ]
    }
  }
}
