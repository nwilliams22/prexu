{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "app": {
    "windows": [
      {
        "title": "Prexu",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "linux": {
      "deb": {
        "depends": ["libmpv2 | libmpv1"]
      },
      "rpm": {
        "depends": ["mpv-libs"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
